---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/posts/PostList';
import ScrollReveal from '../../components/ui/ScrollReveal';
---

<BaseLayout title="文章列表" description="浏览所有已发布的文章">
  <section class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 lg:px-10">
    <div class="mb-10">
      <ScrollReveal client:visible>
        <div class="mb-4 flex items-center gap-3">
          <span class="h-px w-8 bg-stone-400 dark:bg-stone-500"></span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-stone-500 dark:text-stone-400">Articles</span>
        </div>
        <h1 class="text-4xl font-black tracking-tight text-stone-950 dark:text-stone-50 sm:text-5xl">
          所有文章
        </h1>
        <p class="mt-3 max-w-xl text-stone-500 dark:text-stone-400">
          浏览所有已发布的技术文章和思考。
        </p>
      </ScrollReveal>
    </div>

    <PostList client:visible perPage={12} />
  </section>
</BaseLayout>
