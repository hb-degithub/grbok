---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/ui/ScrollReveal';
import { CommentSection } from '../../components/comments/CommentSection';
import { sanitizeHtml } from '../../lib/security';

export function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;

const PB_URL = import.meta.env.PUBLIC_POCKETBASE_URL || 'http://localhost:8090';

interface Post {
  id: string;
  title: string;
  slug: string;
  content: string;
  excerpt: string;
  cover: string;
  status: string;
  published_at: string;
  views: number;
  expand?: {
    author?: {
      name: string;
    };
  };
}

async function fetchPost(postSlug: string): Promise<Post | null> {
  try {
    const safeSlug = postSlug.replace(/["\\]/g, '');
    const filter = `slug="${safeSlug}" && status="published"`;
    const res = await fetch(`${PB_URL}/api/collections/posts/records?filter=${encodeURIComponent(filter)}&expand=author`);
    if (!res.ok) throw new Error(`${res.status}`);
    const data = await res.json();
    return data.items?.[0] ?? null;
  } catch {
    return null;
  }
}

const post = await fetchPost(slug ?? '');

const formattedDate = post?.published_at
  ? new Date(post.published_at).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const readingTime = post?.content
  ? Math.max(1, Math.ceil(post.content.length / 300))
  : 0;

const safeContent = post?.content ? sanitizeHtml(post.content) : '';
---

<BaseLayout title={post?.title || '文章'} description={post?.excerpt || ''}>
  {post ? (
    <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-0">
      <!-- 返回按钮 -->
      <ScrollReveal client:visible>
        <a href="/posts" class="mb-8 inline-flex min-h-11 items-center gap-2 rounded-lg text-stone-500 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          返回文章列表
        </a>
      </ScrollReveal>

      <!-- 文章头部 -->
      <ScrollReveal delay={0.1} client:visible>
        <header class="mb-12">
          <div class="mb-4 flex min-w-0 items-center gap-3">
            <span class="h-px w-8 bg-stone-400 dark:bg-stone-500"></span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-stone-500 dark:text-stone-400">Article</span>
          </div>

          <h1 class="mb-6 break-words font-display text-3xl font-black uppercase leading-tight tracking-wide text-stone-900 [overflow-wrap:anywhere] dark:text-stone-100 sm:text-4xl">
            {post.title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-stone-400 dark:text-stone-500">
            {post.expand?.author && (
              <span class="flex items-center gap-2">
                <span class="h-6 w-6 rounded-full bg-stone-200 dark:bg-stone-700 flex items-center justify-center text-stone-600 dark:text-stone-300 text-[10px]">
                  {post.expand.author.name.charAt(0)}
                </span>
                {post.expand.author.name}
              </span>
            )}
            <span>{formattedDate}</span>
            <span>{readingTime} 分钟阅读</span>
            <span>{post.views} 次浏览</span>
          </div>

          {post.cover && (
            <div class="mt-8 rounded-xl overflow-hidden border border-stone-200 dark:border-stone-700">
              <img src={post.cover} alt={post.title} class="w-full h-auto" loading="lazy" />
            </div>
          )}
        </header>
      </ScrollReveal>

      <!-- 文章内容 -->
      <ScrollReveal delay={0.2} client:visible>
        <div class="prose mb-16 max-w-full break-words [overflow-wrap:anywhere]">
          <div set:html={safeContent} />
        </div>
      </ScrollReveal>

      <!-- 评论区 -->
      <ScrollReveal delay={0.3} client:visible>
        <div class="border-t border-stone-200 pt-12 dark:border-stone-700">
          <CommentSection postId={post.id} client:visible />
      <!-- prev/next navigation -->
      <nav class="mt-8 grid gap-4 sm:grid-cols-2">
        <a href="/posts" class="flex items-center gap-2 rounded-lg border border-stone-200 p-4 text-sm text-stone-600 transition-colors hover:border-stone-300 hover:text-stone-900 dark:border-stone-800 dark:text-stone-400 dark:hover:border-stone-700 dark:hover:text-stone-200">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          <span class="truncate">返回文章列表</span>
        </a>
        <a href="/" class="flex items-center gap-2 justify-end rounded-lg border border-stone-200 p-4 text-sm text-stone-600 transition-colors hover:border-stone-300 hover:text-stone-900 dark:border-stone-800 dark:text-stone-400 dark:hover:border-stone-700 dark:hover:text-stone-200">
          <span class="truncate">返回首页</span>
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </nav>
        </div>
      </ScrollReveal>
    </article>
  ) : (
    <div class="flex flex-col items-center justify-center px-4 py-20 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-lg border border-stone-200 bg-stone-100 dark:border-stone-700 dark:bg-stone-800">
        <svg class="h-8 w-8 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h2 class="font-display text-2xl font-bold text-stone-900 dark:text-stone-100 mb-2">文章不存在</h2>
      <p class="text-stone-500 dark:text-stone-400 mb-6">请先在 PocketBase 中创建文章</p>
      <a href="/posts" class="btn-primary">返回文章列表</a>
    </div>
  )}
</BaseLayout>
