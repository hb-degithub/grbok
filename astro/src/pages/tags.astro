---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ui/ScrollReveal';
import GlowCard from '../components/ui/GlowCard';

const PB_URL = import.meta.env.PUBLIC_POCKETBASE_URL || 'http://localhost:8090';

interface Tag {
  id: string;
  name: string;
  slug: string;
  description: string;
}

async function fetchTags(): Promise<Tag[]> {
  try {
    const res = await fetch(`${PB_URL}/api/collections/tags/records?sort=-created`);
    if (!res.ok) throw new Error(`${res.status}`);
    const data = await res.json();
    return data.items ?? [];
  } catch {
    return [];
  }
}

const tags = await fetchTags();

const tagColors = [
  { bg: 'bg-stone-100 dark:bg-stone-800', text: 'text-stone-700 dark:text-stone-300', border: 'border-stone-200 dark:border-stone-700' },
  { bg: 'bg-zinc-100 dark:bg-zinc-800', text: 'text-zinc-700 dark:text-zinc-300', border: 'border-zinc-200 dark:border-zinc-700' },
  { bg: 'bg-neutral-100 dark:bg-neutral-800', text: 'text-neutral-700 dark:text-neutral-300', border: 'border-neutral-200 dark:border-neutral-700' },
];
---

<BaseLayout title="标签分类" description="按标签筛选文章">
  <section class="mx-auto w-full max-w-5xl px-5 py-16 sm:px-8 lg:px-10">
    <div class="mb-10">
      <ScrollReveal client:visible>
        <div class="mb-4 flex items-center gap-3">
          <span class="h-px w-8 bg-stone-400 dark:bg-stone-500"></span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-stone-500 dark:text-stone-400">Tags</span>
        </div>
        <h1 class="text-4xl font-black tracking-tight text-stone-950 dark:text-stone-50 sm:text-5xl">
          标签分类
        </h1>
        <p class="mt-3 max-w-xl text-stone-500 dark:text-stone-400">
          按标签筛选感兴趣的内容。
        </p>
      </ScrollReveal>
    </div>

    {tags.length === 0 ? (
      <div class="card flex min-h-[22rem] flex-col items-center justify-center rounded-2xl px-6 py-16 text-center">
        <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-xl border border-stone-200 bg-stone-100 dark:border-stone-700 dark:bg-stone-800">
          <svg class="h-8 w-8 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
        <p class="text-stone-500 dark:text-stone-400">暂无标签</p>
        <p class="mt-2 text-sm text-stone-400 dark:text-stone-500">请先在 PocketBase 中创建标签。</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tags.map((tag, index) => {
          const color = tagColors[index % tagColors.length];
          return (
            <ScrollReveal delay={index * 0.1} client:visible>
              <a href={`/tags/${tag.slug}`} class="block no-underline">
                <GlowCard
                  className="card cursor-pointer rounded-2xl p-6 transition-transform hover:-translate-y-1"
                  glowColor={'rgba(120, 113, 108, 0.10)'}
                  client:visible
                >
                  <div class={`mb-4 inline-flex items-center gap-2 rounded-full border ${color.border} ${color.bg} px-3 py-1`}>
                    <span class={`h-1.5 w-1.5 rounded-full bg-current ${color.text}`}></span>
                    <span class={`font-mono text-xs uppercase tracking-wider ${color.text}`}>
                      {tag.name}
                    </span>
                  </div>
                  <h3 class="text-lg font-bold tracking-tight text-stone-900 dark:text-stone-100">
                    {tag.name}
                  </h3>
                  {tag.description && (
                    <p class="mt-2 line-clamp-2 text-sm text-stone-500 dark:text-stone-400">
                      {tag.description}
                    </p>
                  )}
                </GlowCard>
              </a>
            </ScrollReveal>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
