---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ui/ScrollReveal';
import GlowCard from '../components/ui/GlowCard';

const PB_URL = import.meta.env.PUBLIC_POCKETBASE_URL || 'http://localhost:8090';

interface Tag {
  id: string;
  name: string;
  slug: string;
  description: string;
}

async function fetchTags(): Promise<Tag[]> {
  try {
    const res = await fetch(`${PB_URL}/api/collections/tags/records?sort=-created`);
    if (!res.ok) throw new Error(`${res.status}`);
    const data = await res.json();
    return data.items ?? [];
  } catch {
    return [];
  }
}

const tags = await fetchTags();

// 标签颜色映射
const tagColors = [
  { bg: 'bg-cyan/10', text: 'text-cyan', border: 'border-cyan/20' },
  { bg: 'bg-amber/10', text: 'text-amber', border: 'border-amber/20' },
  { bg: 'bg-emerald-500/10', text: 'text-emerald-400', border: 'border-emerald-500/20' },
  { bg: 'bg-violet-500/10', text: 'text-violet-400', border: 'border-violet-500/20' },
  { bg: 'bg-fuchsia-500/10', text: 'text-fuchsia-400', border: 'border-fuchsia-500/20' },
];
---

<BaseLayout title="标签分类" description="按标签筛选文章">
  <div class="mb-12">
    <ScrollReveal client:visible>
      <div class="flex items-center gap-3 mb-4">
        <span class="h-px w-8 bg-amber"></span>
        <span class="font-mono text-[10px] uppercase tracking-widest text-amber">Tags</span>
      </div>
      <h1 class="font-display text-4xl font-black uppercase tracking-wide text-ink">
        标签分类
      </h1>
      <p class="mt-3 text-dim max-w-xl">
        按标签筛选感兴趣的内容
      </p>
    </ScrollReveal>
  </div>

  {tags.length === 0 ? (
    <div class="holo-card flex flex-col items-center justify-center py-20 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-lg border border-line bg-space-light">
        <svg class="h-8 w-8 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
      </div>
      <p class="text-dim">暂无标签</p>
      <p class="mt-2 text-sm text-muted">请先在 PocketBase 中创建标签</p>
    </div>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tags.map((tag, index) => {
        const color = tagColors[index % tagColors.length];
        return (
          <ScrollReveal delay={index * 0.1} client:visible>
            <a href={`/tags/${tag.slug}`} class="block">
              <GlowCard
                className="holo-card p-6 cursor-pointer"
                glowColor={tag.slug === 'tech' ? 'rgba(34, 211, 238, 0.15)' : 'rgba(251, 191, 36, 0.12)'}
                client:visible
              >
                <div class={`inline-flex items-center gap-2 rounded-full ${color.bg} px-3 py-1 mb-4`}>
                  <span class={`h-1.5 w-1.5 rounded-full ${color.text}`}></span>
                  <span class={`font-mono text-xs uppercase tracking-wider ${color.text}`}>
                    {tag.name}
                  </span>
                </div>
                <h3 class="font-display text-lg font-bold uppercase tracking-wide text-ink">
                  {tag.name}
                </h3>
                {tag.description && (
                  <p class="mt-2 text-sm text-dim line-clamp-2">
                    {tag.description}
                  </p>
                )}
              </GlowCard>
            </a>
          </ScrollReveal>
        );
      })}
    </div>
  )}
</BaseLayout>
