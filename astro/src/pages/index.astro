---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="首页" description="欢迎来到我的个人博客">
  <div class="space-y-8">
    <!-- Hero 区域 -->
    <section class="py-12 text-center">
      <h1 class="mb-4 text-4xl font-bold">欢迎来到我的博客</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        分享技术、思考与生活
      </p>
    </section>

    <!-- 最新文章 -->
    <section>
      <h2 class="mb-6 text-2xl font-semibold">最新文章</h2>
      <div class="grid gap-6">
        <!-- 文章卡片将通过 PocketBase API 动态加载 -->
        <p class="text-gray-500">文章加载中...</p>
      </div>
    </section>

    <!-- 快速链接 -->
    <section class="grid gap-4 sm:grid-cols-2">
      <a
        href="/posts"
        class="rounded-lg border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md dark:border-gray-800"
      >
        <h3 class="mb-2 font-semibold">所有文章</h3>
        <p class="text-sm text-gray-500">浏览所有已发布的文章</p>
      </a>
      <a
        href="/tags"
        class="rounded-lg border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md dark:border-gray-800"
      >
        <h3 class="mb-2 font-semibold">标签分类</h3>
        <p class="text-sm text-gray-500">按标签筛选感兴趣的内容</p>
      </a>
    </section>
  </div>
</BaseLayout>
