---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/posts/PostList';
import ScrollReveal from '../components/ui/ScrollReveal';

const PB_URL = import.meta.env.PUBLIC_POCKETBASE_URL || 'http://localhost:8090';

async function fetchCount(collection: string, filter?: string): Promise<number> {
  try {
    const qs = filter ? `?filter=${encodeURIComponent(filter)}&perPage=1` : '?perPage=1';
    const res = await fetch(`${PB_URL}/api/collections/${collection}/records${qs}`);
    if (!res.ok) throw new Error(`${res.status}`);
    const data = await res.json();
    return data.totalItems ?? 0;
  } catch {
    return 0;
  }
}

const [postsCount, tagsCount] = await Promise.all([
  fetchCount('posts', 'status = "published"'),
  fetchCount('tags'),
]);
---

<BaseLayout title="首页" description="欢迎来到我的个人博客">
  <!-- Hero 区域 -->
  <section class="relative -mx-6 -mt-12 overflow-hidden bg-gradient-to-b from-indigo-50/60 via-white to-transparent px-6 pb-20 pt-24 dark:from-indigo-950/20 dark:via-zinc-950">
    <!-- 背景装饰 -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 -translate-y-1/3 rounded-full bg-indigo-500/8 blur-[100px] dark:bg-indigo-500/5"></div>
      <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="relative mx-auto max-w-3xl text-center">
      <!-- 标签 -->
      <div class="animate-enter inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white/60 px-4 py-1.5 text-xs font-medium text-zinc-500 backdrop-blur-sm dark:border-zinc-700 dark:bg-zinc-900/60 dark:text-zinc-400">
        <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
        个人博客
      </div>

      <!-- 标题 -->
      <h1 class="animate-enter mt-6 text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-6xl" style="animation-delay: 0.1s">
        胡巴的博客
      </h1>

      <!-- 副标题 -->
      <p class="animate-enter mx-auto mt-5 max-w-xl text-lg text-zinc-500 dark:text-zinc-400" style="animation-delay: 0.2s">
        分享技术、思考与生活
      </p>

      <!-- 统计 -->
      <div class="animate-enter mt-10 flex items-center justify-center gap-8" style="animation-delay: 0.3s">
        <div class="text-center">
          <div class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">{postsCount}</div>
          <div class="text-xs text-zinc-500 dark:text-zinc-400">文章</div>
        </div>
        <div class="h-8 w-px bg-zinc-200 dark:bg-zinc-700"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">{tagsCount}</div>
          <div class="text-xs text-zinc-500 dark:text-zinc-400">标签</div>
        </div>
      </div>

      <!-- CTA -->
      <div class="animate-enter mt-10" style="animation-delay: 0.4s">
        <a
          href="#latest"
          class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-all hover:bg-indigo-700 hover:shadow-xl hover:-translate-y-0.5"
        >
          浏览文章
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section id="latest" class="mt-16">
    <div class="mb-8 flex items-end justify-between">
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">最新文章</h2>
        <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">最近发布的技术文章和思考</p>
      </div>
      <a href="/posts" class="inline-flex items-center gap-1.5 rounded-full bg-zinc-100 px-4 py-2 text-sm font-medium text-zinc-700 transition-all hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700">
        查看全部
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <PostList client:visible perPage={6} />
  </section>

  <!-- 快速链接 -->
  <section class="mt-20 grid gap-4 sm:grid-cols-2">
    <a href="/posts" class="card-lift group relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white p-7 dark:border-zinc-800/80 dark:bg-zinc-900">
      <div class="relative z-10 flex items-start gap-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-50 dark:bg-indigo-950/30">
          <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">所有文章</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">浏览所有已发布的文章</p>
        </div>
      </div>
    </a>

    <a href="/tags" class="card-lift group relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white p-7 dark:border-zinc-800/80 dark:bg-zinc-900">
      <div class="relative z-10 flex items-start gap-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-50 dark:bg-indigo-950/30">
          <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">标签分类</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">按标签筛选感兴趣的内容</p>
        </div>
      </div>
    </a>
  </section>
</BaseLayout>
