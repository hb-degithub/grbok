---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ui/ScrollReveal';
---

<BaseLayout title="404" description="页面未找到">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <ScrollReveal client:visible>
      <div class="mb-8">
        <h1 class="font-display text-9xl font-black text-stone-300 dark:text-stone-600 animate-glow">
          404
        </h1>
        <p class="mt-4 font-display text-2xl font-bold uppercase tracking-wide text-stone-900 dark:text-stone-100">
          页面未找到
        </p>
        <p class="mt-2 text-stone-500 dark:text-stone-400">
          抱歉，您访问的页面不存在
        </p>
      </div>

      <div class="flex gap-4">
        <a href="/" class="btn-primary">
          返回首页
        </a>
        <a href="/posts" class="btn-ghost">
          浏览文章
        </a>
      </div>
    </ScrollReveal>
  </div>
</BaseLayout>
