---
import BaseLayout from "../layouts/BaseLayout.astro";
const PB_URL = import.meta.env.PUBLIC_POCKETBASE_URL || "http://localhost:8090";
let posts = [];
try {
  const url = PB_URL + "/api/collections/posts/records?sort=-published_at" + "&filter=" + encodeURIComponent('status="published"') + "&fields=id,title,slug,published_at";
  const res = await fetch(url);
  if (res.ok) { const data = await res.json(); posts = data.items ?? []; }
} catch {}
const groups = [];
for (const post of posts) {
  const d = new Date(post.published_at);
  const y = d.getFullYear(); const m = d.getMonth() + 1;
  let yg = groups.find(g => g.year === y);
  if (!yg) { yg = { year: y, months: [] }; groups.push(yg); }
  let mg = yg.months.find(x => x.month === m);
  if (!mg) { mg = { month: m, posts: [] }; yg.months.push(mg); }
  mg.posts.push(post);
}
---
<BaseLayout title="文章归档" description="按时间归档">
<section class="mx-auto max-w-4xl px-5 py-16">
<h1 class="text-3xl font-black">文章归档</h1>
<p class="mt-2 text-zinc-500">共{posts.length}篇</p>
{groups.map(y => <div key={y.year}>
  <h2 class="mt-8 text-2xl font-bold">{y.year}</h2>
  {y.months.map(m => <div key={m.month} class="ml-4 mt-4">
    <h3 class="text-sm font-mono text-zinc-400">{m.month}月</h3>
    <div class="mt-2 space-y-1">
      {m.posts.map(p => <a href={"/posts/" + p.slug} class="flex items-center gap-3 py-1.5 text-sm hover:text-zinc-900">
        {new Date(p.published_at).toLocaleDateString("zh-CN",{month:"2-digit",day:"2-digit"})}
        <span>{p.title}</span>
      </a>)}
    </div>
  </div>)}
</div>)}
</section>
</BaseLayout>
