---
import { SITE_CONFIG } from '../../config/site';
const currentYear = new Date().getFullYear();
---

<footer class="mt-24 border-t border-zinc-200/70 bg-white dark:border-zinc-800/80 dark:bg-zinc-950">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-12">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start sm:justify-between">
      <!-- 站点信息 -->
      <div class="flex flex-col items-center gap-2 text-center sm:items-start sm:text-left">
        <div class="flex items-center gap-2">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-900 text-sm font-bold text-white dark:bg-zinc-100 dark:text-zinc-900">B</span>
          <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">{SITE_CONFIG.name}</span>
        </div>
        <p class="text-xs text-zinc-500 dark:text-zinc-400 max-w-xs">{SITE_CONFIG.description}</p>
        <p class="text-xs text-zinc-400 dark:text-zinc-500">&copy; {currentYear} {SITE_CONFIG.author}. All rights reserved.</p>
      </div>

      <!-- 社交链接 -->
      <div class="flex items-center gap-3">
        {SITE_CONFIG.socialLinks.map((link) => (
          <a
            key={link.name}
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-500 transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-zinc-200"
            aria-label={link.name}
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              {link.name === "github" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />}
              {link.name === "twitter" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" />}
              {link.name !== "github" && link.name !== "twitter" && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />}
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- 备案链接 -->
    <div class="mt-8 flex flex-col items-center gap-3 border-t border-zinc-200/70 pt-6 dark:border-zinc-800/70 sm:flex-row sm:justify-center sm:gap-6">
      {SITE_CONFIG.icp.url && (
        <a href={SITE_CONFIG.icp.url} target="_blank" rel="noopener noreferrer" class="beian-link">
          <svg class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 3.75h7.35L18.25 7.7v12.55H7V3.75Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
            <path d="M14.25 4v4h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9.7 12h5.8M9.7 15.25h5.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
          <span>{SITE_CONFIG.icp.text}</span>
        </a>
      )}
      {SITE_CONFIG.police.url && (
        <a href={SITE_CONFIG.police.url} target="_blank" rel="noopener noreferrer" class="beian-link">
          <svg class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 2L2 5v4c0 5.25 3.5 10.15 8 11 4.5-.85 8-5.75 8-11V5l-8-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
            <path d="M7.5 10.5L9.5 12.5L12.5 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{SITE_CONFIG.police.text}</span>
        </a>
      )}
    </div>

    <p class="mt-4 text-center text-[10px] text-zinc-400 dark:text-zinc-600">Powered by Astro &amp; PocketBase</p>
  </div>
</footer>

<style>
  .beian-link, .beian-link:visited {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: rgb(120 113 108);
    text-decoration: none !important;
    line-height: 1.5;
    max-width: 100%;
    min-width: 0;
    transition: color 150ms ease;
  }
  .beian-link:hover, .beian-link:focus-visible {
    color: rgb(28 25 23);
    text-decoration: none !important;
  }
  :global(.dark) .beian-link, :global(.dark) .beian-link:visited {
    color: rgb(168 162 158);
  }
  :global(.dark) .beian-link:hover, :global(.dark) .beian-link:focus-visible {
    color: rgb(245 245 244);
  }
  @media (max-width: 420px) {
    .beian-link { width: min(100%, 19rem); white-space: normal; justify-content: center; text-align: center; }
  }
</style>
