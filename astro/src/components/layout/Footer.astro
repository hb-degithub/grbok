---
import { SITE_CONFIG } from '../../config/site';
---

<footer class="mt-24 border-t border-stone-200/70 bg-white dark:border-stone-800/80 dark:bg-stone-950">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-center gap-3 px-4 py-8 text-center text-sm sm:flex-row sm:flex-wrap sm:gap-x-6 sm:gap-y-3 sm:px-6 sm:text-left">
    <a
      href={SITE_CONFIG.icp.url}
      target="_blank"
      rel="noopener noreferrer"
      class="beian-link"
    >
      <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M7 3.75h7.35L18.25 7.7v12.55H7V3.75Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
        <path d="M14.25 4v4h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M9.7 12h5.8M9.7 15.25h5.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
      <span>{SITE_CONFIG.icp.text}</span>
    </a>

    <a
      href={SITE_CONFIG.police.url}
      target="_blank"
      rel="noopener noreferrer"
      class="beian-link"
    >
      <img src="/beian-police.png" alt="" class="h-4 w-4 flex-shrink-0" loading="lazy" />
      <span>{SITE_CONFIG.police.text}</span>
    </a>
  </div>
</footer>

<style>
  .beian-link,
  .beian-link:visited {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: rgb(120 113 108);
    text-decoration: none !important;
    line-height: 1.5;
    max-width: 100%;
    min-width: 0;
    white-space: nowrap;
    transition: color 150ms ease, opacity 150ms ease;
  }

  .beian-link:hover,
  .beian-link:focus-visible {
    color: rgb(28 25 23);
    text-decoration: none !important;
  }

  :global(.dark) .beian-link,
  :global(.dark) .beian-link:visited {
    color: rgb(168 162 158);
  }

  :global(.dark) .beian-link:hover,
  :global(.dark) .beian-link:focus-visible {
    color: rgb(245 245 244);
  }

  @media (max-width: 420px) {
    .beian-link {
      width: min(100%, 19rem);
      white-space: normal;
      justify-content: center;
      text-align: center;
    }
  }
</style>
