    "updateRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && post_id.author.id = @request.auth.id)",
    "deleteRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && post_id.author.id = @request.auth.id)"
