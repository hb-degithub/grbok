    "updateRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && author.id = @request.auth.id)",
    "deleteRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && author.id = @request.auth.id)"
  },
  "comments": {
    "listRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && post_id.author.id = @request.auth.id)",
    "viewRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && post_id.author.id = @request.auth.id)",
    "createRule": "post_id.status = \"published\"",
    "updateRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\"",
    "deleteRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\""
  },
  "public_comments": {
    "listRule": "",
    "viewRule": "",
