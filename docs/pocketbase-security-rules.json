  "settings": {
    "listRule": "(key = \"site_title\" || key = \"site_description\" || key = \"site_logo\" || key = \"posts_per_page\" || key = \"enable_comments\" || key = \"comment_moderation\" || key = \"debug_protection_enabled\") || @request.auth.role = \"super_admin\"",
    "viewRule": "(key = \"site_title\" || key = \"site_description\" || key = \"site_logo\" || key = \"posts_per_page\" || key = \"enable_comments\" || key = \"comment_moderation\" || key = \"debug_protection_enabled\") || @request.auth.role = \"super_admin\"",
