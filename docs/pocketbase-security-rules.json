  },
  "tags": {
    "listRule": "",
    "viewRule": "",
    "createRule": "@request.auth.role = \"author\" || @request.auth.role = \"admin\" || @request.auth.role = \"super_admin\"",
    "updateRule": "@request.auth.role = \"author\" || @request.auth.role = \"admin\" || @request.auth.role = \"super_admin\"",
    "deleteRule": "@request.auth.role = \"admin\" || @request.auth.role = \"super_admin\""
  },
  "post_tags": {
    "listRule": "",
    "viewRule": "",
