{
  "users": {
    "listRule": "id = @request.auth.id || @request.auth.role = \"super_admin\"",
    "viewRule": "id = @request.auth.id || @request.auth.role = \"super_admin\"",
    "createRule": "@request.auth.role = \"super_admin\" || @request.data.role = \"reader\" || @request.data.role = \"\"",
    "updateRule": "id = @request.auth.id || @request.auth.role = \"super_admin\"",
    "deleteRule": "@request.auth.role = \"super_admin\""
  },
  "posts": {
    "listRule": "status = \"published\" || @request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && author.id = @request.auth.id)",
    "viewRule": "status = \"published\" || @request.auth.role = \"admin\" || @request.auth.role = \"super_admin\" || (@request.auth.role = \"author\" && author.id = @request.auth.id)",
