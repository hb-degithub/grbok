# ===========================
# 涓汉鍗氬鐢熶骇鐜閰嶇疆
# ===========================

# 鍩熷悕閰嶇疆
DOMAIN=blog.example.com

# PocketBase 绠＄悊鍛?IP 鐧藉悕鍗?(閫楀彿鍒嗛殧澶氫釜 IP)
ADMIN_IP=127.0.0.1

# Caddy ACME 璇佷功閭
CADDY_ACME_EMAIL=admin@example.com

# 鍏ㄥ眬 Rate Limit (姣忕姣?IP 璇锋眰鏁?
RATE_LIMIT_PER_IP=10

# 鐧诲綍绔偣 Rate Limit (姣忓垎閽熸瘡 IP 璇锋眰鏁? 閰嶅悎鏈嶅姟绔?5 娆″け璐ュ皝绂?
LOGIN_RATE_LIMIT_PER_MINUTE=5

# 澶囦唤淇濈暀澶╂暟
BACKUP_RETENTION_DAYS=30

# 鏃跺尯
TZ=Asia/Shanghai

# PocketBase 鍔犲瘑瀵嗛挜 (蹇呴』浣跨敤 openssl rand -hex 32 鐢熸垚)
# 鐢熸垚鍛戒护: openssl rand -hex 32
PB_ENCRYPTION_KEY=your_32_byte_hex_key_here

# 闃块噷浜戦偖浠舵帹閫?SMTP 鍑瘉
# 娉ㄦ剰: 浣跨敤 SMTP 涓撶敤鍑瘉锛岄潪 API Key
# 鑾峰彇浣嶇疆: 闃块噷浜戞帶鍒跺彴 鈫?閭欢鎺ㄩ€?鈫?SMTP 璁剧疆
ALIYUN_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_SMTP_PORT=465
ALIYUN_SMTP_USER=smtp_xxx@xxx.example.com
ALIYUN_SMTP_PASSWORD=your_smtp_password_here
ALIYUN_FROM_EMAIL=noreply@example.com
ALIYUN_FROM_NAME=涓汉鍗氬

# 内部 admin-auth 服务配置
ADMIN_AUTH_INTERNAL_SECRET=change-me-32-chars-minimum
ADMIN_AUTH_HASH_SECRET=change-me-32-chars-minimum
ADMIN_AUTH_RP_ID=hlydwz.com
ADMIN_AUTH_ORIGIN=https://hlydwz.com
ADMIN_AUTH_SESSION_TTL_SECONDS=900
