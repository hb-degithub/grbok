# ===========================
# 个人博客生产环境配置
# ===========================

# 域名配置
DOMAIN=blog.example.com

# PocketBase 管理员 IP 白名单 (逗号分隔多个 IP)
ADMIN_IP=127.0.0.1

# Caddy ACME 证书邮箱
CADDY_ACME_EMAIL=admin@example.com

# 全局 Rate Limit (每秒每 IP 请求数)
RATE_LIMIT_PER_IP=10

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 时区
TZ=Asia/Shanghai

# PocketBase 加密密钥 (必须使用 openssl rand -hex 32 生成)
# 生成命令: openssl rand -hex 32
PB_ENCRYPTION_KEY=your_32_byte_hex_key_here

# 阿里云邮件推送 SMTP 凭证
# 注意: 使用 SMTP 专用凭证，非 API Key
# 获取位置: 阿里云控制台 → 邮件推送 → SMTP 设置
ALIYUN_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_SMTP_PORT=465
ALIYUN_SMTP_USER=smtp_xxx@xxx.example.com
ALIYUN_SMTP_PASSWORD=your_smtp_password_here
ALIYUN_FROM_EMAIL=noreply@example.com
ALIYUN_FROM_NAME=个人博客
