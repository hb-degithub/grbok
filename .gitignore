# ===========================
# Git 忽略规则
# ===========================

# 敏感配置（全部忽略，仅保留模板）
.env
.env.local
.env.production
.env.astro
!.env.example

# Docker 数据卷（运行时生成）
pb_data/

# pb_hooks 需要提交（包含自定义 hooks 代码）

# IDE
.vscode/
.idea/
.claude/settings.local.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node.js
node_modules/
dist/
.cache/

# 日志
*.log
logs/

# 备份文件
backups/
*.tar.gz
*.zip

# 临时文件
tmp/
temp/

# 临时调试文件 (仅根目录, 不影响 pb_hooks/*.pb.js 和 src 下的 js)
/*.js
/*.bat
/*.vbs
/*.png
/*.jpg
/*.err
/*.log
# SSH 私钥（禁止提交）
*_key
*_ed25519
*.pem
*.key
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk

# 部署临时文件
deploy-*.tar.gz
deploy-*.zip
